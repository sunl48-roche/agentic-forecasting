# E2B Code Execution Service
E2B_API_KEY=<E2B API key from your coder env>

# Local Build-CLI Service
PROXY_BASE_URL=https://us.build-cli.roche.com/proxy
PROXY_API_KEY=
ANTHROPIC_CUSTOM_HEADERS=x-build-cli-tool: claude

# Langfuse — required for trace logging in playground/news_search and misalignment_qa
LANGFUSE_PUBLIC_KEY=<langfuse public key from your coder env>
LANGFUSE_SECRET_KEY=<langfuse secret key from your coder env>
LANGFUSE_HOST=https://us.cloud.langfuse.com

# Optional keys
FRED_API_KEY=<your fred api key>

# Tavily
TAVILY_API_KEY=<your tavily api key>
